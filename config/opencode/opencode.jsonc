{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "plugin": [
    "opencode-claude-bridge@1.8.0"
  ],
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "git push *": "ask",
      "git commit *": "ask",
      "git reset *": "ask",
      "terraform *": "ask",
      "sed *": "ask",
    },
    "webfetch": "allow"
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder:30b": {
          "name": "qwen3-coder:30b"
        }
      }
    }
  }
}
