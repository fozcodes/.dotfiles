{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "system",
  "keybinds": {
    "messages_line_up": "alt+k",
    "messages_line_down": "alt+j",
    "messages_half_page_up": "ctrl+alt+k",
    "messages_half_page_down": "ctrl+alt+j",
    "input_newline": "shift+return,ctrl+return,alt+return"
  }
}
